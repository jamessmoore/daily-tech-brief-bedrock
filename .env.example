# Copy to .env for local testing only. Real values are never committed —
# in deployment they come from Secrets Manager (see terraform/secrets.tf).

# Bedrock model ID (or cross-region inference profile ID) for Claude Sonnet 4.6.
# Find it with: aws bedrock list-foundation-models --query "modelSummaries[?contains(modelId,'sonnet')].modelId"
BEDROCK_MODEL_ID=

AWS_REGION=us-east-1

# Tavily API key, used by app/tools/web_search.py
TAVILY_API_KEY=

# Slack bot token (chat:write scope), used by app/slack_mcp_server/index.js
SLACK_BOT_TOKEN=

# Slack channel the brief is posted to
SLACK_CHANNEL=#daily-brief
